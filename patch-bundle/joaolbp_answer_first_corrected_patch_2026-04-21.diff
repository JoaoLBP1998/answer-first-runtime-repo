+      ],
+      "verification_mode": "LIVE_CHECK_REQUIRED" | "LIVE_CHECK_PLUS_PACKET_CONTEXT" | "DOSSIER_COVERED",
+      "result": "SUPPORTED" | "PARTIAL" | "UNSUPPORTED" | "CONTRADICTED",
